{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@mohak34/opencode-notifier"],
  "compaction": {
    "auto": false
  },
	"permission": {
		"bash": {
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git show*": "allow",
			"git ls-files*": "allow",
			"git check-ignore*": "allow",
			"git branch*": "deny",
			"git branch -a*": "allow",
			"git branch -r*": "allow",
			"git tag*": "deny",
			"git checkout*": "deny",
			"git add*": "allow",
			"git reset*": "deny",
			"git rebase*": "deny",
			"git stash*": "deny",
			"git merge*": "deny",
			"git rm*": "ask",
			"git mv*": "ask",
			"git restore*": "deny",
			"git cherry-pick*": "deny",
			"git revert*": "deny",
			"git clean*": "deny",
			"git pull*": "deny",
			"git submodule*": "deny",
			"git push*": "deny",
			"git commit*": "ask",
			"rm -rf *": "ask",
			"rm -r *": "ask"
		}
	},
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}